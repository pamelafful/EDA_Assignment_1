
# Estimating factor scores by maximum likelihood
factanal(scale(Data2),factors=2,rotation="none")

# Estimating factor scores by PCA
svd.out <- svd(cor(Data2))
svd.d <- sqrt(svd.out$d)  # d of cov/cor matrix is d-square of X, see bottom p11
svd.v <- svd.out$v
Lmat <- svd.v %*% diag(svd.d)
Lmat[,1:2]

plot (svd.d, type="b")

# reconstruct correlation (standadised covariance) matrix
Rhat <- Lmat[,1:2] %*% t(Lmat[,1:2]) + diag(Lmat[,3:7] %*% t(Lmat[,3:7]))
Rhat
cor(Data2)
