v=numeric()
function1 <- function(a) {
  for(i in 1:a){
    df5<-df %>% filter(df$Sex=="F") %>% select(Mass,Unique.ID)
    df5$Mass<-as.numeric(df5$Mass)
    X<-sample(df5$Mass,size=1)
    df6<-df %>% filter(df$Sex=="M") %>% select(Mass,Unique.ID)
